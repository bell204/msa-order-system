<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bienbetter.order.mapper.OrderMapper">

    <insert id="insertOrder" parameterType="com.bienbetter.order.entity.Order">
        INSERT INTO TB_ORDER (
            order_id,
            user_id,
            item_name,
            amount,
            order_date
        ) VALUES (
            #{orderId},
            #{userId},
            #{itemName},
            #{amount},
            COALESCE(#{orderDate}, CURRENT_TIMESTAMP)
        )
    </insert>

</mapper>